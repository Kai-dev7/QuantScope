# QuantScope 前端生产环境配置
# 构建命令: npm run build -- --mode production
# 此文件在 build 时被 Vite 自动读取（VITE_* 前缀的变量会被注入）

# ═══════════════════════════════════════════════════════════
# API 配置（必须）
# ═══════════════════════════════════════════════════════════
# 后端 API 地址（相对路径，生产环境通过 Nginx 代理）
# 如果使用独立域名，改为绝对路径，例如：
#   VITE_API_BASE_URL=https://api.510168.xyz/api
VITE_API_BASE_URL=/api

# WebSocket 地址（相对路径）
VITE_WS_URL=/ws

# ═══════════════════════════════════════════════════════════
# 应用配置（可选）
# ═══════════════════════════════════════════════════════════
VITE_APP_TITLE=QuantScope
VITE_DEFAULT_DEPTH=standard