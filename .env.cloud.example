# QuantScope 生产环境配置模板（腾讯云）
# ═══════════════════════════════════════════════════════════════════════
# 使用方法：复制此文件为 .env.cloud，填入真实密钥
# ═══════════════════════════════════════════════════════════════════════

# ===== 云端部署标识 =====
DOCKER_CONTAINER=true

# ===== 数据库配置（本地 MongoDB Docker 容器）=====
# MongoDB 容器暴露在 localhost:27017
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=tradingagents123
MONGODB_DATABASE=tradingagents
MONGODB_AUTH_SOURCE=admin
MONGODB_URL=mongodb://admin:tradingagents123@localhost:27017/tradingagents?authSource=admin
MONGO_URI=mongodb://admin:tradingagents123@localhost:27017/tradingagents?authSource=admin
MONGO_DB=tradingagents
MONGODB_CONNECTION_STRING=mongodb://admin:tradingagents123@localhost:27017/tradingagents?authSource=admin
MONGODB_DATABASE_NAME=tradingagents
USE_MONGODB_STORAGE=true

# ===== Redis（腾讯云轻量本地 redis-server）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=tradingagents123
REDIS_DB=0
REDIS_URL=redis://:tradingagents123@localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ===== 必需的 API Keys =====
# ⚠️  必须修改！以下填写你自己的密钥
DASHSCOPE_API_KEY=<你的阿里云百炼 API Key>
DASHSCOPE_ENABLED=true

# 其他 API Keys（按需启用）
DEEPSEEK_API_KEY=
DEEPSEEK_ENABLED=false

# ===== 服务配置 =====
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
TZ=Asia/Shanghai

# ===== 日志配置 =====
TRADINGAGENTS_LOG_LEVEL=INFO
TRADINGAGENTS_LOG_DIR=/app/logs
TRADINGAGENTS_LOG_FILE=/app/logs/tradingagents.log
LOG_LEVEL=INFO

# ===== API 服务配置（仅监听本地，Nginx 代理）=====
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=false

# ===== CORS =====
ALLOWED_ORIGINS=["http://150.158.144.155"]
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=*

# ===== JWT（⚠️ 生产环境建议修改！）=====
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
CSRF_SECRET=change-this-too
BCRYPT_ROUNDS=12

# ===== 数据目录 =====
TRADINGAGENTS_DATA_DIR=/app/data
TRADINGAGENTS_CACHE_DIR=/app/data/cache
TRADINGAGENTS_SESSIONS_DIR=/app/data/sessions
TRADINGAGENTS_LOGS_DIR=/app/data/logs
TRADINGAGENTS_CONFIG_DIR=/app/data/config
TRADINGAGENTS_TEMP_DIR=/app/data/temp
TRADINGAGENTS_RESULTS_DIR=/app/data/analysis_results

# ===== 内存配置 =====
MEMORY_ENABLED=true

# ===== 成本跟踪 =====
ENABLE_COST_TRACKING=true
COST_ALERT_THRESHOLD=100.0
MAX_USAGE_RECORDS=10000

# ===== 并发控制 =====
DEFAULT_USER_CONCURRENT_LIMIT=3
GLOBAL_CONCURRENT_LIMIT=50
DEFAULT_DAILY_QUOTA=1000

# ===== 队列配置 =====
QUEUE_MAX_SIZE=10000
QUEUE_VISIBILITY_TIMEOUT=300
QUEUE_MAX_RETRIES=3

# ===== 分析师配置 =====
MARKET_ANALYST_LOOKBACK_DAYS=365
PARALLEL_ANALYST_PIPELINE_ENABLED=true
LLM_JUDGE_ENABLED=true
LLM_JUDGE_MAX_RETRIES=1
NEWS_ANALYST_LLM_PREPROCESS_ENABLED=false
DASHSCOPE_OPENAI_MAX_RETRIES=3
DASHSCOPE_OPENAI_RETRY_BASE_SECONDS=1.5
DASHSCOPE_OPENAI_TIMEOUT_SECONDS=45
DASHSCOPE_OPENAI_CLIENT_MAX_RETRIES=0

# ===== 数据源 =====
DEFAULT_CHINA_DATA_SOURCE=akshare

# ===== 缓存 =====
TA_USE_APP_CACHE=true
CACHE_TTL=3600
SCREENING_CACHE_TTL=1800
SESSION_EXPIRE_HOURS=24